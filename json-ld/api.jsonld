    "observation": "inat:Observation",
    "taxon": "inat:Taxon",
    "identification": "inat:Identification",
    "place": "inat:Place",
    "project": "inat:Project",
    "user": "inat:User",
    "quality_grade": "inat:qualityGrade",
    "observed_on": "inat:observedOn",
    "captive": "inat:captive",
    "introduced": "inat:introduced",
    "native": "inat:native",
    "endemic": "inat:endemic",
    "coordinates_obscured": "inat:coordinatesObscured",
    "license_code": "schema:license",
    "created_at": "schema:dateCreated",
    "updated_at": "schema:dateModified",
    "description": "schema:description",
    "url": "schema:url",
    "id": "@id",
    "type": "@type"
  },
  "@type": "WebAPI",
