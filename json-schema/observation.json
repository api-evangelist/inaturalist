      "type": "integer"
    },
    "quality_grade": {
      "type": "string"
    },
    "reviewed_by": {
      "type": "array",
      "items": {
        "type": "integer"
      }
    },
    "site_id": {
      "type": "integer"
    },
    "sounds": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/Sound"
      }
    },
    "species_guess": {
      "type": "string"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "taxon": {
      "$ref": "#/definitions/ObservationTaxon"
