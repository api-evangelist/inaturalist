{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Sound",
  "type": "object",
  "properties": {
    "id": {
      "type": "integer"
    },
    "attribution": {
      "type": "string"
    },
    "license_code": {
      "type": "string"
    },
    "file_url": {
      "type": "string"
    },
    "file_content_type": {
      "type": "string"
    },
    "flags": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/Flag"
      }
    },
    "hidden": {
      "type": "boolean"
    },
    "moderator_actions": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/ModeratorAction"
      }
    }
  }
}